# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry Error Monitoring (optional but recommended for production)
# Get your DSN from https://sentry.io/settings/projects/
VITE_SENTRY_DSN=https://xxxxxx@yyyyyy.ingest.sentry.io/zzzzzz

# E2E Test Credentials (used by Playwright tests in e2e/)
# IMPORTANT: Change these before running tests in production
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASS=CHANGEME_STRONG_PASSWORD_REQUIRED_123!
E2E_AGENT_EMAIL=agent@example.com
E2E_AGENT_PASS=CHANGEME_STRONG_PASSWORD_REQUIRED_123!
E2E_CUSTOMER_EMAIL=customer@example.com
E2E_CUSTOMER_PASS=CHANGEME_STRONG_PASSWORD_REQUIRED_123!
E2E_OPERATOR_EMAIL=operator@example.com
E2E_OPERATOR_PASS=CHANGEME_STRONG_PASSWORD_REQUIRED_123!

# Build mode
# Set to "true" for HashRouter (GitHub Pages)
# VITE_USE_HASH_ROUTER=true
